# A dotenv file rendered by tplr, e.g. to seed a container at startup.
#
#   tplr --source example/secrets.env.tmpl --dest .env --env prod --region eu-central-1
#
APP_NAME={{env:APP_NAME | default "myapp"}}
DB_PASSWORD={{aws:secretsmanager:app/{{env | toLower}}/db#password}}
API_KEY={{aws:ssm:/app/{{env | toLower}}/api-key}}

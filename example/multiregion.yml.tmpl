# Pulling values from several AWS regions / partitions in one file.
# Each placeholder can pin its own region with aws@REGION:, overriding --region.
#
#   tplr --source example/multiregion.yml.tmpl --dest config.yml
#
commercial:
  dbPassword: {{aws@eu-central-1:secretsmanager:app/db#password}}

# AWS European Sovereign Cloud (separate partition, *.amazonaws.eu endpoints).
sovereign:
  dbPassword: {{aws@eusc-de-east-1:secretsmanager:app/db#password}}
